# ─── Database (Supabase Postgres) ───────────────────────────────────
# Source: Supabase Project Settings -> Database -> Connection string.
# Pooled connection (pgBouncer, port 6543). Required for runtime.
DATABASE_URL=
# Direct connection (port 5432). Required for migrations.
DIRECT_URL=

# ─── Auth / Session ────────────────────────────────────────────────
# Random secret, >=32 chars. Generate: openssl rand -hex 32
SESSION_SECRET=
SESSION_COOKIE_SECURE=

# ─── Cron / API secrets ────────────────────────────────────────────
# Protects cron endpoints (/api/cron/*). Required in production.
CRON_SECRET=

# ─── App settings ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=
APP_VERSION=
FREE_ONLY_MODE=
AI_PROVIDER_MODE=
AI_ALLOW_PAID=
ALLOW_SQLITE_DEV=

# ─── Convex (optional unless realtime features are enabled) ─────────
# Source: Convex dashboard (deployment settings).
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# ─── Feature flags ─────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_COMMAND_PALETTE=
NEXT_PUBLIC_FEATURE_UNIFIED_CHAT=
NEXT_PUBLIC_FEATURE_CUSTOM_SHORTCUTS=
NEXT_PUBLIC_FEATURE_CLOUD_AI_GATEWAY=
NEXT_PUBLIC_FEATURE_COMPONENTS_SHOWROOM=
NEXT_PUBLIC_FEATURE_REPORTS_PDF=
NEXT_PUBLIC_FEATURE_VOICE_INPUT=
NEXT_PUBLIC_FEATURE_WINDOW_CONTROLS_OVERLAY=

# ─── Washer Kiosk Mode ─────────────────────────────────────────────
# KIOSK_TOKEN=""
# KIOSK_STATION_ID="station-1"

# ─── Viber Bridge (optional, one-way mirror) ───────────────────────
# FEATURE_VIBER_BRIDGE="0"
# VIBER_BOT_TOKEN=""
# VIBER_TARGET_GROUP_ID=""
# VIBER_WEBHOOK_SECRET=""
# VIBER_BRIDGE_MODE="one-way"

# ─── Content refresh intervals ─────────────────────────────────────
# FEEDS_REFRESH_MINUTES="30"
# WEATHER_CACHE_MINUTES="30"
# SEARCH_TRIGRAM_ENABLED="1"

# ─── AI providers (free-only policy — leave blank) ─────────────────
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# OPENROUTER_API_KEY=""
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
