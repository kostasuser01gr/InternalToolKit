# InternalToolKit — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit real secrets.

# ── Database ──
# Get both URLs from Supabase: Project Settings -> Database -> Connection string.
# DATABASE_URL should use pooled/pgBouncer (port 6543).
DATABASE_URL=
# DIRECT_URL should use direct Postgres (port 5432).
DIRECT_URL=

# ── Auth ──
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Kiosk ──
KIOSK_TOKEN=
KIOSK_STATION_ID=

# ── Feature Flags (all default to true unless noted) ──
NEXT_PUBLIC_FEATURE_COMMAND_PALETTE=
NEXT_PUBLIC_FEATURE_COMPONENTS_SHOWROOM=
NEXT_PUBLIC_FEATURE_REPORTS_PDF=
NEXT_PUBLIC_FEATURE_VOICE_INPUT=
NEXT_PUBLIC_FEATURE_UNIFIED_CHAT=
NEXT_PUBLIC_FEATURE_CUSTOM_SHORTCUTS=
NEXT_PUBLIC_FEATURE_CLOUD_AI_GATEWAY=
NEXT_PUBLIC_FEATURE_WINDOW_CONTROLS_OVERLAY=

# New feature flags (Phase 7)
NEXT_PUBLIC_FEATURE_KIOSK_PRESETS=
NEXT_PUBLIC_FEATURE_OFFLINE_QUEUE=
NEXT_PUBLIC_FEATURE_FLEET_QC_STEP=
NEXT_PUBLIC_FEATURE_FLEET_SLA_ALERTS=
NEXT_PUBLIC_FEATURE_SHIFT_PUBLISH_LOCK=
NEXT_PUBLIC_FEATURE_CHAT_ENTITY_THREADS=
NEXT_PUBLIC_FEATURE_COORDINATOR_DASHBOARD=

# ── Convex ──
# Get these from the Convex dashboard when Convex is enabled.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
